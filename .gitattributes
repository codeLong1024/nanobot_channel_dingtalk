# 统一换行符处理
# 所有文本文件在仓库中存储为 LF，检出时根据 OS 自动转换
* text=auto

# Python 文件强制使用 LF
*.py text eol=lf

# 配置文件
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# 许可证和文档
LICENSE text eol=lf
README.md text eol=lf

# Windows 脚本保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 二进制文件不转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pyc binary
*.pyo binary
*.whl binary
*.zip binary
*.tar.gz binary
